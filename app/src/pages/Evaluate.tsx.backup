/* ═══════════════════════════════════════════════════════════════════════════
   SALARY RANGES BY COUNTRY (₹ Lakhs) — Entry / Mid / Senior
   Entry = fresh grad, Mid = 3-5 yrs, Senior = 8+ yrs
   ═══════════════════════════════════════════════════════════════════════════ */
const SALARY_RANGE: Record<string, { entry: number; mid: number; senior: number }> = {
  Canada:     { entry: 38, mid: 55, senior: 85 },
  Germany:    { entry: 35, mid: 50, senior: 75 },
  UK:         { entry: 32, mid: 48, senior: 72 },
  USA:        { entry: 50, mid: 85, senior: 150 },
  Australia:  { entry: 35, mid: 52, senior: 78 },
  Ireland:    { entry: 30, mid: 45, senior: 68 },
  Netherlands:{ entry: 34, mid: 50, senior: 74 },
  "New Zealand": { entry: 28, mid: 42, senior: 62 },
  Sweden:     { entry: 30, mid: 44, senior: 65 },
  France:     { entry: 26, mid: 40, senior: 58 },
  Singapore:  { entry: 38, mid: 60, senior: 95 },
  UAE:        { entry: 30, mid: 50, senior: 80 },
  Italy:      { entry: 20, mid: 32, senior: 48 },
  Poland:     { entry: 16, mid: 26, senior: 40 },
  Malaysia:   { entry: 14, mid: 22, senior: 35 },
  "South Korea": { entry: 22, mid: 35, senior: 55 },
  Russia:     { entry: 12, mid: 20, senior: 32 },
  Georgia:    { entry: 10, mid: 16, senior: 26 },
  Philippines:{ entry: 8,  mid: 14, senior: 22 },
};

/* Helper: get salary range display string */
function getSalaryRange(country: string): string {
  const r = SALARY_RANGE[country];
  if (!r) return "N/A";
  return `₹${r.entry}–${r.senior}L`;
}

/* ---- Compute functions (enhanced) ---- */
function compute(country: string, track: Track, level: Level, major: Major) {
  let baseTuition = BASE_TUITION[country] || 10;
  // Germany private universities have real tuition (€5K-20K/yr)
  if (country === "Germany" && track === "Private") {
    baseTuition = 18;
  }
  const tuition = track === "Govt" 
    ? baseTuition * STREAM_MULT[major] * 0.6 
    : baseTuition * STREAM_MULT[major];

  // ─── Living cost with 10% annual increase ───
  // Year 1 = base, Year 2 = +10%, Year 3 = +21%, Year 4 = +33.1%
  const baseLiving = LIVING[country] || 10;
  const duration = DURATION[level];
  let totalLiving = 0;
  for (let yr = 0; yr < duration; yr++) {
    totalLiving += baseLiving * Math.pow(1.10, yr);
  }
  const living = Math.round(totalLiving * 10) / 10;

  const earnings = (EARN[country] || 20) * (duration / 4);
  const netOOP = Math.round((tuition + living - earnings) * 10) / 10;

  // ─── 3-Year ROI: cumulative 3-year salary / Net OOP ───
  // Uses mid-level salary (3-5 yrs experience) for realistic projection
  const sr = SALARY_RANGE[country];
  const midSalary = sr ? sr.mid : SALARY[country];
  const threeYearSalary = midSalary * 3;
  const roi = netOOP > 0 ? Math.round((threeYearSalary / netOOP) * 10) / 10 : null;

  // ─── Ideal Budget: Net OOP + 20% buffer ───
  const idealBudget = netOOP > 0 ? Math.round(netOOP * 1.2 * 10) / 10 : 0;

  // ─── Lifetime ROI: 10-year earnings + benefits vs education cost ───
  const lv = LIFETIME_VALUE[country];
  let lifetimeValue = 0;
  if (lv && netOOP > 0) {
    const tenYearEarnings = midSalary * lv.salaryGrowth10Yr;
    const healthcareSaved = lv.healthcareAnnual * 10;
    const educationSaved = lv.educationPerChild * 1;
    const prFastTrackBonus = lv.prToCitizenshipYrs <= 6 ? 15 :
                              lv.prToCitizenshipYrs <= 10 ? 8 : 0;
    lifetimeValue = tenYearEarnings + healthcareSaved + educationSaved + prFastTrackBonus;
  }
  const lifetimeROI = netOOP > 0 ? Math.round((lifetimeValue / netOOP) * 10) / 10 : null;

  return {
    tuition: Math.round(tuition * 10) / 10,
    living,
    earnings: Math.round(earnings * 10) / 10,
    netOOP,
    idealBudget,
    roi,
    lifetimeValue: Math.round(lifetimeValue * 10) / 10,
    lifetimeROI,
    salary: midSalary,               // Single number for calculations
    salaryRange: getSalaryRange(country), // Display string like "₹38–85L"
    salaryEntry: sr ? sr.entry : SALARY[country],
    salarySenior: sr ? sr.senior : SALARY[country],
    employment: EMPLOYMENT[country] || 5,
    visaEase: VISA_EASE[country] || 5,
    prScore: PR_SCORE[country] || 5,
    safety: INDIAN_SAFETY[country] || 70,
  };
}

/* Helper: get work experience visa bonus for display */
function getWorkExpBonus(country: string, workExp: WorkExpLevel): number {
  return WORK_EXP_VISA_BONUS[country]?.[workExp] || 0;
}

function score(country: string, track: Track, level: Level, major: Major, budget: number, prPriority: PRPriority, ielts: number, acad: number, workExp: WorkExpLevel) {
  let base = (FIT_BASE[country] || 5) * STREAM_MULT[major] * 0.6;
  let penalty = 0;
  const fin = compute(country, track, level, major);

  // ─── 1. BUDGET PENALTY (less aggressive) ───
  // UG naturally costs more (4 yrs vs 2 yrs) — scale budget expectation
  const levelBudgetMult = level === "UG" ? 1.6 : 1.0; // UG costs ~60% more
  const adjustedBudget = budget * levelBudgetMult;
  if (fin.netOOP > 0) {
    const ratio = adjustedBudget / fin.netOOP;
    // Was: >=1→0, >=0.7→1, >=0.5→2, else→3
    // Now: >=1→0, >=0.6→0.5, >=0.4→1.5, else→2.5
    penalty += ratio >= 1 ? 0 : ratio >= 0.6 ? 0.5 : ratio >= 0.4 ? 1.5 : 2.5;
  }

  // ─── 2. IELTS PENALTY ───
  penalty += ielts >= 7 ? 0 : ielts >= 6.5 ? 0.5 : ielts >= 6 ? 1 : ielts >= 5.5 ? 1.5 : 2.5;

  // ─── 3. ACADEMIC PENALTY ───
  penalty += acad >= 65 ? 0 : acad >= 55 ? 0.5 : 1;

  // ─── 4. PR PENALTY (only heavy when PR Priority = High) ───
  if (prPriority === "High" && (country === "UAE" || country === "Philippines")) penalty += 2;
  if (prPriority === "High" && fin.prScore < 5) penalty += 0.5; // Slight nudge for low-PR countries

  // ─── 5. SAFETY BONUS / PENALTY ───
  if (fin.safety >= 85) base += 0.3;
  else if (fin.safety < 65) penalty += 0.5; // Was <70, now <65 (USA=72 safe)

  // ─── 6. VISA EASE BONUS (0.0-0.4) ───
  base += (fin.visaEase / 10) * 0.4;

  // ─── 7. PR TIMELINE BONUS (0.0-0.4, weighted by user priority) ───
  const prWeight = prPriority === "High" ? 1.0 : prPriority === "Med" ? 0.6 : 0.3;
  base += (fin.prScore / 10) * 0.4 * prWeight;

  // ─── 8. EMPLOYMENT BONUS (0.0-0.3) ───
  base += (fin.employment / 10) * 0.3;

  // ─── 9. POST-STUDY SALARY PREMIUM BONUS ───
  // Uses ENTRY-LEVEL salary (conservative) for bonus — what fresh grads actually earn
  if (fin.salaryEntry >= 45) base += 0.4;      // ₹45L+ entry (USA, Singapore)
  else if (fin.salaryEntry >= 35) base += 0.25; // ₹35L+ entry (Canada, Germany, Australia)
  else if (fin.salaryEntry >= 28) base += 0.15; // ₹28L+ entry (UK, Ireland, NZ)
  else if (fin.salaryEntry >= 20) base += 0.05;

  // ─── 9b. LIFETIME VALUE BONUS ───
  // Countries with strong long-term PR benefits get a bonus
  // This captures what basic ROI misses: 10yr earnings + healthcare + education
  if (fin.lifetimeROI && fin.lifetimeROI > 0) {
    if (fin.lifetimeROI >= 50) base += 0.6;      // Lifetime return 50x+ (Canada PR pathway)
    else if (fin.lifetimeROI >= 30) base += 0.4;  // 30x+ (Australia, Germany)
    else if (fin.lifetimeROI >= 15) base += 0.25; // 15x+ (UK, Ireland)
    else if (fin.lifetimeROI >= 8) base += 0.1;   // 8x+ (modest)
  }
  // Direct long-term multiplier bonus (captures earning growth trajectory)
  const lv = LIFETIME_VALUE[country];
  if (lv) {
    if (lv.longTermMultiplier >= 1.4) base += 0.3;  // USA exceptional growth
    else if (lv.longTermMultiplier >= 1.25) base += 0.2; // Canada/Germany/Australia
    else if (lv.longTermMultiplier >= 1.1) base += 0.1;
    else if (lv.longTermMultiplier < 0.9) penalty += 0.2; // No long-term value
  }

  // ─── 10. EARNING POTENTIAL DURING STUDY ───
  // Countries where part-time earnings offset costs better
  if (fin.earnings >= 25) base += 0.15; // High part-time earnings (Australia)

  // ─── 11. GERMANY BLOCKED ACCOUNT ───
  if (country === "Germany" && budget < 20) penalty += 0.8;

  // ─── 12. WORK EXPERIENCE BONUS ───
  const weBonus = (WORK_EXP_VISA_BONUS[country]?.[workExp] || 0) / 10;
  if (level === "PG") {
    base += weBonus * 0.8;
  } else {
    base += weBonus * 0.3;
  }

  // ─── 13. MBA WORK EX PENALTY ───
  if (level === "PG" && major === "Mgmt" && (workExp === "0" || workExp === "0-1")) {
    penalty += 1.0; // Was 1.5, reduced
  }

  return Math.max(0, Math.min(10, Math.round((base - penalty) * 10) / 10));
}

function evaluateAll(params: { courseType: CourseType; level: Level; major: Major; budget: number; prPriority: PRPriority; ielts: number; track: Track; region: RegionFilter; workExp: WorkExpLevel }) {
  const { level, major, budget, prPriority, ielts, track, region, workExp } = params;
  let acad = 80;
  let countries = COUNTRIES;
  if (region !== "Any") {
    countries = COUNTRIES.filter(c => c === region);
    if (countries.length === 0) countries = COUNTRIES;
  }
  const results = countries.map(country => {
    const s = score(country, track, level, major, budget, prPriority, ielts, acad, workExp);
    const fin = compute(country, track, level, major);
    const weBonus = getWorkExpBonus(country, workExp);
    return {
      country, score: s, ...fin,
      visa: VISA[country], pr: PR_PATH[country], job: JOB[country],
      jobNumeric: fin.employment,
      workExpBonus: weBonus,
      idealBudget: fin.idealBudget,
      lifetimeValue: fin.lifetimeValue,
      lifetimeROI: fin.lifetimeROI,
      salaryRange: fin.salaryRange,
      salaryEntry: fin.salaryEntry,
      salarySenior: fin.salarySenior,
      _rank: 0
    };
  });
  results.sort((a, b) => b.score - a.score || a.country.localeCompare(b.country));
  results.forEach((r, i) => r._rank = i + 1);
  return results;
}

const formatROI = (r: number | null) => r === null ? "—" : `${r}x`;
const formatMoney = (v: number) => `₹${v.toFixed(1)}L`;
const scoreColor = (s: number) => s >= 7.5 ? "text-emerald-600" : s >= 5 ? "text-amber-600" : "text-red-600";
const roiColor = (r: number | null) => { if (r === null) return "text-gray-500"; return r >= 2 ? "text-emerald-600" : r >= 1 ? "text-amber-600" : "text-red-600"; };
const jobBg = (j: string) => j === "High" ? "bg-emerald-100 text-emerald-700" : j === "Medium" ? "bg-amber-100 text-amber-700" : "bg-red-100 text-red-700";

